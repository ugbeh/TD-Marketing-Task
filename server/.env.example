# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskmanager
DB_USER=postgres
DB_PASSWORD=your_database_password

# ── Server ────────────────────────────────────────────────────
PORT=3001

# ── App URL ───────────────────────────────────────────────────
# Development: http://localhost:5173
# Production:  https://yourdomain.com
APP_URL=http://localhost:5173

# ── Auth ──────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(48).toString('hex').then? '' : console.log(require('crypto').randomBytes(48).toString('hex'))"
# Or in Node REPL: require('crypto').randomBytes(48).toString('hex')
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Email (optional — for "Forgot password" emails) ───────────
# Leave blank to use the console-log fallback (admin shares link manually).
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=datateam@tdafrica.com
# SMTP_PASS=your_email_password
# SMTP_FROM=TD Africa Data Team <datateam@tdafrica.com>
